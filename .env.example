# Copy to .env and edit before running
MOCK_MODE=true
DEFAULT_HANDLE=bogamie
LOG_LEVEL=INFO
APP_ENV=development
DATA_DIR=./data

# !! Generate a real secret: openssl rand -hex 32
SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_EXPIRE_DAYS=7
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_REGISTER_MAX_ATTEMPTS=15
AUTH_LOGIN_MAX_ATTEMPTS=30
AUTH_LOGIN_MAX_FAILURES=5
AUTH_ACCOUNT_LOCK_MINUTES=15
EMAIL_CODE_TTL_MINUTES=10

# CAPTCHA
CAPTCHA_REQUIRED=false
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify

# Brevo SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Baekjoon Recommender
SMTP_USE_TLS=true

# Redis (optional — remove to disable)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Recommendation engine
WEIGHT_DIFFICULTY=0.35
WEIGHT_WEAKNESS=0.30
WEIGHT_TAG_PRIORITY=0.20
WEIGHT_EXPLORATION=0.15
TIER_GAP_MIN=-1
TIER_GAP_MAX=2
DEFAULT_REC_COUNT=10
INACTIVITY_THRESHOLD_DAYS=60
INACTIVITY_TIER_PENALTY=1
