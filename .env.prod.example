# Database
DB_USERNAME=app
DB_PASSWORD=change-me-strong-password

# JWT — 최소 32바이트 이상 (예: openssl rand -base64 48)
JWT_SECRET=change-me-long-random-secret

# CORS (comma-separated if multiple)
ALLOWED_ORIGINS=https://bogamie.github.io

# Gmail SMTP (use App Password, not account password)
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_APP_PASSWORD=your-app-password
